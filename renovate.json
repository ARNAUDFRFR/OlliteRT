{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["gradle"],
      "enabled": false
    },
    {
      "matchManagers": ["gradle"],
      "matchPackageNames": ["com.google.ai.edge.litertlm:**"],
      "enabled": true,
      "groupName": "LiteRT-LM",
      "automerge": false
    }
  ],
  "schedule": ["* * */4 * *"]
}
